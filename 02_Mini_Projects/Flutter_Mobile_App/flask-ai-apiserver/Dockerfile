# ----------------------------------------------------
#  Python 3.11 Slim 베이스 이미지
# ----------------------------------------------------
FROM python:3.11-slim

# ----------------------------------------------------
#  작업 디렉토리 생성
# ----------------------------------------------------
WORKDIR /app

# ----------------------------------------------------
#  OS 패키지 업데이트 및 의존성 설치
#  필요한 경우만 최소 설치 → 이미지 슬림하게 유지
# ----------------------------------------------------
RUN apt-get update && apt-get install -y \
    build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ----------------------------------------------------
#  Python 종속성 설치
#  requirements 먼저 복사 → 캐시 최적화
# ----------------------------------------------------
COPY requirements.txt .

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# ----------------------------------------------------
#  Flask 앱 파일 복사
# ----------------------------------------------------
COPY . .

# ----------------------------------------------------
#  Flask 기본 포트는 5000
# ----------------------------------------------------
EXPOSE 5000

# ----------------------------------------------------
#  Gunicorn으로 프로덕션 실행
#  (Flask 내장 서버는 배포용이 아님)
# ----------------------------------------------------
CMD ["gunicorn", "-w", "1", "-t", "120", "-b", "0.0.0.0:5000", "api_v2:app"]